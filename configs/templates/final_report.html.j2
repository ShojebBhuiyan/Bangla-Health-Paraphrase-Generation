<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Final Report - {{ experiment }}</title>
  <style>
    body { font-family: Georgia, serif; max-width: 960px; margin: 2rem auto; padding: 0 1rem; }
    h1, h2 { color: #2E86AB; }
    table { border-collapse: collapse; width: 100%; margin: 1rem 0; }
    th, td { border: 1px solid #ccc; padding: 0.5rem; }
    th { background: #f0f4f8; }
    pre { background: #f8f8f8; padding: 1rem; overflow-x: auto; }
  </style>
</head>
<body>
  <h1>Final Research Report</h1>
  <p><strong>Experiment:</strong> {{ experiment }}</p>
  <p><a href="{{ eda_link }}">EDA Report</a></p>

  <h2>Model Results</h2>
  {% if metrics %}
  <table>
    <tr>
      <th>Model</th>
      <th>BLEU</th>
      <th>ROUGE-L</th>
      <th>BERTScore</th>
      <th>Distinct-1</th>
      <th>Distinct-2</th>
      <th>SemSim (mpnet)</th>
      <th>SemSim (bn-sbert)</th>
    </tr>
    {% for m in metrics %}
    <tr>
      <td>{{ m.model_key }}</td>
      <td>{{ "%.2f"|format(m.BLEU) }}</td>
      <td>{{ "%.4f"|format(m["ROUGE-L"]) }}</td>
      <td>{{ "%.4f"|format(m.BERTScore) }}</td>
      <td>{{ "%.4f"|format(m["Distinct-1"]) }}</td>
      <td>{{ "%.4f"|format(m["Distinct-2"]) }}</td>
      <td>{{ "%.4f"|format(m.get("semsim_mpnet", 0)) }}</td>
      <td>{{ "%.4f"|format(m.get("semsim_bnsbert", 0)) }}</td>
    </tr>
    {% endfor %}
  </table>
  {% else %}
  <p>No evaluation metrics available yet.</p>
  {% endif %}

  <h2>Configuration Snapshot</h2>
  <pre>{{ config_yaml }}</pre>
</body>
</html>
